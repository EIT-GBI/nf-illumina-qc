manifest {
    name            = 'nf-__NAME__'
    description     = 'Nextflow pipeline for __NAME__'
    version         = '0.0.0'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=25.04.0'
}

params {
    // TODO: declare pipeline parameters
    input  = null
    outdir = 'results'
}

// Base directory for the workflow `output {}` block.
// Override on the CLI with `-output-dir <path>` or via `--outdir <path>`.
outputDir = params.outdir

includeConfig 'conf/base.config'

profiles {
    docker {
        docker.enabled = true
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }
    test {
        includeConfig 'conf/test.config'
    }
}
